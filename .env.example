# ─── Server ───
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# Public URL the API answers on. Used for outbound webhook callback URLs
# (e.g. Twilio status callback). MUST be set in production.
BASE_URL=http://localhost:3000

# ─── Database ───
DATABASE_URL=postgresql://dentaflow:dentaflow@localhost:5432/dentaflow

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
# Required, ≥ 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ─── Credentials Encryption (AES-256-GCM) ───
# Required. 64-char hex string (32 bytes). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# ─── External scoring service ───
SCORING_SERVICE_URL=http://localhost:8001/api/v1/scoring
SCORING_SERVICE_TIMEOUT_MS=10000

# ─── External HTTP defaults ───
EXTERNAL_HTTP_TIMEOUT_MS=5000

# ─── Twilio (SMS + WhatsApp) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
# Set to true in production once Twilio is configured.
# When true, /api/v1/webhooks/twilio rejects requests without a valid signature.
VERIFY_TWILIO_SIGNATURE=false

# ─── SendGrid (Email) ───
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@dentaflow.local
# Base64-encoded ECDSA verification key from the SendGrid Event Webhook UI.
SENDGRID_WEBHOOK_PUBLIC_KEY=
VERIFY_SENDGRID_SIGNATURE=false

# ─── Google OAuth (for SSO) ───
GOOGLE_CLIENT_ID=

# ─── CORS ───
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:5173

# ─── No-Show Scoring ───
CHRONIC_THRESHOLD=0.7

# ─── Real-time / SSE ───
MAX_SSE_CONNECTIONS_PER_USER=5

# ─── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Google Review Collection ─────────────────────────────────────────────────
# Public-facing base URL (used in SMS/WhatsApp/Email review links)
REVIEW_BASE_URL=https://your-domain.com
# Get from Google Maps → Share → Embed a map → extract placeid=...
# Used as fallback if clinic doesn't have a googlePlaceId in DB
GOOGLE_PLACE_ID_FALLBACK=ChIJ...
