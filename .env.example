# ─── Database ───
DATABASE_URL=postgresql://dentaflow:dentaflow@localhost:5432/dentaflow

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=24h

# ─── Credentials Encryption (AES-256-GCM) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=your_64_char_hex_string_here

# ─── Twilio (SMS + WhatsApp) ───
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── SendGrid (Email) ───
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@dentaflow.local

# ─── Google OAuth (for SSO) ───
GOOGLE_CLIENT_ID=your_google_client_id

# ─── CORS ───
ALLOWED_ORIGINS=http://localhost:5173

# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── No-Show Scoring ───
CHRONIC_THRESHOLD=0.7

# ─── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Google Review Collection ─────────────────────────────────────────────────
# Public-facing base URL (used in SMS/WhatsApp/Email review links)
REVIEW_BASE_URL=https://your-domain.com
# Get from Google Maps → Share → Embed a map → extract placeid=...
# Used as fallback if clinic doesn't have a googlePlaceId in DB
GOOGLE_PLACE_ID_FALLBACK=ChIJ...
